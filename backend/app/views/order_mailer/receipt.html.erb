<div style="background-color: #f8fafc; padding: 40px 20px; font-family: 'Outfit', 'Inter', -apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, sans-serif; color: #1e293b; line-height: 1.5; margin: 0;">
  <div style="max-width: 600px; margin: 0 auto; background-color: #ffffff; border-radius: 16px; border: 1px solid #e2e8f0; overflow: hidden; box-shadow: 0 4px 6px -1px rgba(0, 0, 0, 0.05);">
    
    <!-- Top Decorative Gradient Header -->
    <div style="background: linear-gradient(135deg, #4f46e5 0%, #7c3aed 100%); padding: 32px; text-align: center; color: #ffffff;">
      <h1 style="margin: 0; font-size: 28px; font-weight: 700; letter-spacing: -0.025em;">EZ-Shop</h1>
      <p style="margin: 8px 0 0 0; font-size: 16px; opacity: 0.9;">Order Confirmed & Paid</p>
    </div>

    <!-- Main Content Body -->
    <div style="padding: 32px;">
      
      <!-- Greeting and Confirmation -->
      <div style="text-align: center; margin-bottom: 32px;">
        <div style="display: inline-block; background-color: #ecfdf5; border-radius: 50%; padding: 12px; margin-bottom: 16px;">
          <!-- SVG Checkmark -->
          <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="#10b981" stroke-width="3" stroke-linecap="round" stroke-linejoin="round" style="display: block;">
            <polyline points="20 6 9 17 4 12"></polyline>
          </svg>
        </div>
        <h2 style="margin: 0; font-size: 20px; font-weight: 600; color: #0f172a;">Thank you for your purchase!</h2>
        <p style="margin: 4px 0 0 0; font-size: 14px; color: #64748b;">We've received your payment and are preparing your order.</p>
      </div>

      <!-- Order Info Metadata -->
      <table width="100%" cellpadding="0" cellspacing="0" border="0" style="margin-bottom: 32px; border-bottom: 1px solid #f1f5f9; padding-bottom: 24px;">
        <tr>
          <td width="50%" valign="top" style="padding-right: 16px;">
            <p style="margin: 0 0 4px 0; font-size: 11px; text-transform: uppercase; font-weight: 700; letter-spacing: 0.05em; color: #94a3b8;">Order Details</p>
            <p style="margin: 0 0 4px 0; font-size: 14px; font-weight: 600; color: #334155;">ID: <span style="font-family: monospace; color: #4f46e5;">#<%= @order.orderid %></span></p>
            <p style="margin: 0 0 4px 0; font-size: 13px; color: #475569;">Date: <%= @order.createdAt.in_time_zone('Asia/Kuala_Lumpur').strftime('%B %d, %Y %I:%M %p') %></p>
            <p style="margin: 0; font-size: 13px; color: #475569;">Payment: <span style="text-transform: capitalize;"><%= @order.paymentMethod.to_s.gsub('_', ' ') %></span></p>
          </td>
          <td width="50%" valign="top" style="padding-left: 16px;">
            <p style="margin: 0 0 4px 0; font-size: 11px; text-transform: uppercase; font-weight: 700; letter-spacing: 0.05em; color: #94a3b8;">Shipping Address</p>
            <p style="margin: 0 0 2px 0; font-size: 14px; font-weight: 600; color: #334155;"><%= @customer.name %></p>
            <p style="margin: 0 0 2px 0; font-size: 13px; color: #475569;"><%= @customer.phone %></p>
            <p style="margin: 0; font-size: 13px; color: #475569; line-height: 1.4;"><%= @customer.shoppingAddress %></p>
          </td>
        </tr>
      </table>

      <!-- Items Section -->
      <h3 style="margin: 0 0 16px 0; font-size: 14px; font-weight: 700; text-transform: uppercase; letter-spacing: 0.05em; color: #94a3b8;">Items Ordered</h3>
      
      <table width="100%" cellpadding="0" cellspacing="0" border="0" style="margin-bottom: 24px; border-collapse: collapse;">
        <% @order_items.each do |item| %>
          <tr style="border-bottom: 1px solid #f1f5f9;">
            <td style="padding: 12px 0; width: 56px;" valign="middle">
              <% if item.product&.image.present? %>
                <img src="<%= item.product.image %>" alt="<%= item.product.name %>" width="48" height="48" style="display: block; border-radius: 8px; object-fit: cover; border: 1px solid #e2e8f0;" />
              <% else %>
                <div style="width: 48px; height: 48px; border-radius: 8px; background-color: #f1f5f9; text-align: center; line-height: 48px; color: #94a3b8; font-size: 12px; font-weight: bold; border: 1px solid #e2e8f0;">No Img</div>
              <% end %>
            </td>
            <td style="padding: 12px 12px;" valign="middle">
              <p style="margin: 0; font-size: 14px; font-weight: 600; color: #1e293b;"><%= item.product&.name %></p>
              <p style="margin: 2px 0 0 0; font-size: 12px; color: #64748b;">Size: <%= item.product&.size %> | Qty: <%= item.quantity %></p>
            </td>
            <td style="padding: 12px 0; text-align: right;" valign="middle">
              <p style="margin: 0; font-size: 14px; font-weight: 600; color: #1e293b;"><%= number_to_currency(item.subtotal) %></p>
              <p style="margin: 2px 0 0 0; font-size: 11px; color: #64748b;"><%= number_to_currency(item.unitPrice) %> each</p>
            </td>
          </tr>
        <% end %>
      </table>

      <!-- Order Calculations -->
      <table width="100%" cellpadding="0" cellspacing="0" border="0" style="border-top: 1px solid #f1f5f9; padding-top: 16px; margin-bottom: 24px;">
        <!-- Subtotal -->
        <tr>
          <td style="padding: 4px 0; font-size: 14px; color: #64748b;">Subtotal</td>
          <td style="padding: 4px 0; text-align: right; font-size: 14px; font-weight: 600; color: #334155;"><%= number_to_currency(@order.subtotal) %></td>
        </tr>
        
        <!-- Discounts -->
        <% if @order.item_discount > 0 %>
          <tr>
            <td style="padding: 4px 0; font-size: 14px; color: #ef4444;">
              Discount
              <% promo_codes = @order_promotions.reject { |op| op.promotion&.discountTarget == 'shipping' }.map { |op| op.promotion&.promoCode }.compact %>
              <% if promo_codes.any? %>
                <span style="font-size: 11px; background-color: #fef2f2; color: #ef4444; padding: 2px 6px; border-radius: 4px; font-family: monospace; font-weight: bold; margin-left: 4px;"><%= promo_codes.join(', ') %></span>
              <% end %>
            </td>
            <td style="padding: 4px 0; text-align: right; font-size: 14px; font-weight: 600; color: #ef4444;">-<%= number_to_currency(@order.item_discount) %></td>
          </tr>
        <% end %>

        <!-- Shipping -->
        <tr>
          <td style="padding: 4px 0; font-size: 14px; color: #64748b;">
            Shipping
            <% if @order.shipping_discount > 0 %>
              <% ship_codes = @order_promotions.select { |op| op.promotion&.discountTarget == 'shipping' }.map { |op| op.promotion&.promoCode }.compact %>
              <% if ship_codes.any? %>
                <span style="font-size: 11px; background-color: #f0fdf4; color: #15803d; padding: 2px 6px; border-radius: 4px; font-family: monospace; font-weight: bold; margin-left: 4px;"><%= ship_codes.join(', ') %></span>
              <% end %>
            <% end %>
          </td>
          <td style="padding: 4px 0; text-align: right; font-size: 14px; font-weight: 600; color: #334155;">
            <% if @order.shipping_cost == 0 %>
              <span style="color: #10b981; font-weight: bold;">FREE</span>
            <% else %>
              <%= number_to_currency(@order.shipping_cost) %>
            <% end %>
          </td>
        </tr>

        <!-- Grand Total -->
        <tr>
          <td style="padding: 16px 0 0 0; font-size: 18px; font-weight: 700; color: #0f172a; border-top: 1px solid #f1f5f9; margin-top: 8px;">Total Paid</td>
          <td style="padding: 16px 0 0 0; text-align: right; font-size: 20px; font-weight: 800; color: #4f46e5; border-top: 1px solid #f1f5f9; margin-top: 8px;"><%= number_to_currency(@order.finalTotal) %></td>
        </tr>
      </table>

    </div>

    <!-- Footer -->
    <div style="background-color: #f8fafc; padding: 24px; text-align: center; border-top: 1px solid #e2e8f0;">
      <p style="margin: 0 0 8px 0; font-size: 13px; color: #64748b;">If you have any questions or concerns about this receipt, please contact our support team.</p>
      <p style="margin: 0; font-size: 12px; color: #94a3b8;">&copy; 2026 EZ-Shop. All rights reserved.</p>
    </div>

  </div>
</div>
